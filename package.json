{
  "name": "@stackra/nestjs-types",
  "version": "1.0.0",
  "description": "NestJS interfaces, types, enums, and constants extracted from @nestjs/common, @nestjs/microservices, and @nestjs/websockets",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "keywords": [
    "nestjs",
    "types",
    "interfaces",
    "enums",
    "typescript"
  ],
  "author": "Stackra",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
