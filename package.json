{
  "name": "@stackra/nestjs-types",
  "version": "1.0.0",
  "description": "NestJS interfaces, types, enums, and constants extracted from @nestjs/common, @nestjs/microservices, and @nestjs/websockets",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nestjs",
    "types",
    "interfaces",
    "enums",
    "typescript"
  ],
  "author": "Stackra",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "module": "./dist/index.js"
}
